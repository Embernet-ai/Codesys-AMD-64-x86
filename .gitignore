# =============================================================================
# EmberNET Helm Chart Repository — .gitignore
# =============================================================================

# Helm build artifacts (CI/CD generates these on gh-pages branch)
*.tgz
index.yaml
.deploy/

# IDE & OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Archive (old chart versions — keep tracked but ignore new additions)
# _archive/ is tracked intentionally

# Allow these files through
!.gitignore
!.gitattributes
!.nojekyll
!.github/
!.github/**
!README.md
!RELEASE_CHECKLIST.md
!CHANGELOG.md
!charts/
!charts/**
!icon.png
!_archive/
!_archive/**
